{
  "name": "zawaj-api",
  "version": "1.0.0",
  "description": "Zawaj API - Cloudflare Workers backend",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
